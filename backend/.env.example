# Example environment variables for local development
# For Firebase Admin: either set GOOGLE_APPLICATION_CREDENTIALS to a local file path
# or set FIREBASE_SERVICE_ACCOUNT_JSON to the JSON content (escape newlines as needed).
DATABASE_URL=postgres://user:password@localhost:5432/cafefinder
ADMIN_SECRET=change-me-for-local-testing
# Optionally: FIREBASE_SERVICE_ACCOUNT_JSON='{...}'
